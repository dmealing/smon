<style>.hdr{font-family:sans-serif;padding:12px 16px;border-radius:6px;background:#eee}.hdr .e{display:none;font-size:1.4em}.hdr-fail .e-fail,.hdr-warn .e-warn,.hdr-recovery .e-recovery{display:inline}</style>
<div class="hdr hdr-{{kind}}"><span class="e e-fail">🔴</span><span class="e e-warn">🟠</span><span class="e e-recovery">🟢</span> <strong>{{verdict.status}}</strong> — {{probe}} on {{host}} ({{verdict.tag}})</div>
<p>{{enrichedBody}}</p>